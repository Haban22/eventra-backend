              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{attendee_id}}\",\n  \"action\": \"RSVP_EVENT\",\n  \"referenceId\": \"ref_rsvp_test_123\",\n  \"displayName\": \"Gamified User\",\n  \"avatarUrl\": \"http://example.com/avatar.png\"\n}",
              "options": {
                "raw": {
                  "language": "json"
