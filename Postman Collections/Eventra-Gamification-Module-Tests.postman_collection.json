{
  "info": {
    "_postman_id": "67f6a0b3-c603-4990-81d8-c5fd3624629f",
    "name": "Eventra - Gamification Module Integration Tests",
    "description": "Integration tests for the Gamification Module, covering rewards profiles, awarding XP/points for user actions, redeeming points, transactions history, badges unlock status, and leaderboard retrieval.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Authentication",
      "item": [
        {
          "name": "Attendee Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman_attendee@eventra.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Token is returned\", function () {",
                  "    pm.expect(jsonData.access_token).to.not.be.undefined;",
                  "});",
                  "pm.collectionVariables.set(\"attendee_token\", jsonData.access_token);",
                  "if (jsonData.user && jsonData.user.id) {",
                  "    pm.collectionVariables.set(\"attendee_id\", jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Profile Management",
      "item": [
        {
          "name": "Create/Retrieve Rewards Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{attendee_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/gamification/profile",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "gamification",
                "profile"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{attendee_id}}\",\n  \"displayName\": \"Gamified User\",\n  \"avatarUrl\": \"http://example.com/avatar.png\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Profile creation successful\", function () {",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data.level).to.not.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Rewards Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{attendee_token}}"
