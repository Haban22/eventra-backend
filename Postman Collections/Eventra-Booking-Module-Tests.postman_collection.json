    {
      "name": "3. Booking Management",
      "item": [
        {
          "name": "Create Booking (Hold)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{attendee_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/bookings",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "bookings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"ticketId\": \"{{vipTicketId}}\",\n  \"quantity\": 2,\n  \"paymentMethod\": \"CREDIT_CARD\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Verify status is PENDING_PAYMENT\", function() {",
                  "    pm.expect(jsonData.status).to.eql(\"PENDING_PAYMENT\");",
                  "});",
                  "pm.test(\"Verify amount is 200.00\", function() {",
                  "    pm.expect(parseFloat(jsonData.totalAmount)).to.eql(200.00);",
                  "});",
                  "pm.test(\"Verify items contains ticket details\", function() {",
                  "    pm.expect(jsonData.items.length).to.eql(1);",
                  "    pm.expect(jsonData.items[0].quantity).to.eql(2);",
                  "});",
                  "pm.collectionVariables.set(\"bookingId\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
