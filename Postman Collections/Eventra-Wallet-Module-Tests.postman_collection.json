                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin Reject Payout Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/admin/wallet/payout-requests/{{payout_request_id_reject}}/reject",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "admin",
                "wallet",
                "payout-requests",
                "{{payout_request_id_reject}}",
                "reject"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Missing organizer identity verification documents.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.expect(jsonData.status).to.eql(\"REJECTED\");",
                  "pm.expect(jsonData.rejectionReason).to.eql(\"Missing organizer identity verification documents.\");"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
