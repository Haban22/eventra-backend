            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50.0,\n  \"methodId\": \"{{payout_method_id}}\",\n  \"notes\": \"Requesting payout to be rejected.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
