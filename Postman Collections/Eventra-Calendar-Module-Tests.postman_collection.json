{
  "info": {
    "_postman_id": "2e38fd69-6c3b-4a5b-8d83-be3ef9831fc6",
    "name": "Eventra - Calendar Module Integration Tests",
    "description": "Integration tests for the Calendar Module, covering retrieval of personal calendar events, creating personal events/reminders, and deleting calendar events.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Authentication",
      "item": [
        {
          "name": "Attendee Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman_attendee@eventra.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Token is returned\", function () {",
                  "    pm.expect(jsonData.access_token).to.not.be.undefined;",
                  "});",
                  "pm.collectionVariables.set(\"attendee_token\", jsonData.access_token);",
                  "if (jsonData.user && jsonData.user.id) {",
                  "    pm.collectionVariables.set(\"attendee_id\", jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Personal Calendar",
      "item": [
        {
          "name": "Create Personal Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{attendee_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/calendar",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "calendar"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Attend Tech Conference Prep\",\n  \"description\": \"Read papers and prepare questions for the Tech Conference.\",\n  \"date\": \"2026-10-15T09:00:00Z\",\n  \"endDate\": \"2026-10-15T11:00:00Z\",\n  \"location\": \"Online / Meeting Room A\",\n  \"type\": \"personal\",\n  \"category\": \"Education\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.expect(jsonData.id).to.not.be.undefined;",
                  "pm.collectionVariables.set(\"personal_event_id\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get My Calendar Events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{attendee_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/calendar/me",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "calendar",
                "me"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.expect(jsonData).to.be.an('array');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Personal Event",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{attendee_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/calendar/{{personal_event_id}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "calendar",
                "{{personal_event_id}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "attendee_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "personal_event_id",
      "value": "",
      "type": "string"
    }
  ]
}