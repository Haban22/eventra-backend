# Copy this file to .env and fill in your local values.
# .env is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
spring.datasource.url=jdbc:postgresql://localhost:5432/eventra_db
spring.datasource.username=postgres
spring.datasource.password=your_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
spring.data.redis.host=localhost
spring.data.redis.port=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
app.jwt-secret=replace-with-a-random-secret-at-least-32-characters-long
app.jwt-access-expiry-seconds=86400
app.jwt-refresh-expiry-seconds=604800

# ── App ───────────────────────────────────────────────────────────────────────
app.frontend-url=http://localhost:5173
app.bcrypt-strength=10
# Leave blank to disable Google login
app.google-client-id=

# ── Mail ──────────────────────────────────────────────────────────────────────
app.mail-from=noreply@eventra.com
spring.mail.host=smtp.gmail.com
spring.mail.port=587
# For Gmail, generate an App Password at myaccount.google.com/apppasswords
spring.mail.username=your-email@gmail.com
spring.mail.password=your-gmail-app-password

# ── CORS ──────────────────────────────────────────────────────────────────────
cors.allowed-origins=http://localhost:5173
app.cors-allowed-origins=http://localhost:5173

# ── Eventra AI microservice ───────────────────────────────────────────────────
eventra.ai.url=http://localhost:8001
