{
  "info": {
    "_postman_id": "ed9659cb-3174-42cc-8f92-79eb4ae81c1d",
    "name": "Eventra - M1 Auth & User Module Integration Tests",
    "description": "Integration tests for the Auth & User Module (M1) of Eventra Backend, covering registration, email verification, login rate limits, token rotation, profile management, organizer upgrades, and admin ban/reactivation workflows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication & Lifecycle",
      "item": [
        {
          "name": "Register Attendee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/register/attendee",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "register",
                "attendee"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"New Attendee\",\n  \"email\": \"{{register_email}}\",\n  \"password\": \"Password123\",\n  \"phone\": \"+1234567890\",\n  \"city\": \"Amman\",\n  \"interests\": [\n    \"Tech\",\n    \"Music\",\n    \"Sports\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"register_email\", \"attendee_\" + Math.floor(Math.random() * 1000000) + \"@example.com\");"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Response message is correct\", function () {",
                  "    pm.expect(jsonData.message).to.eql(\"Verification email sent\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
